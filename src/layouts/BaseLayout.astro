---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SmartOrders — Gestión de pedidos para lecherías',
  description = 'Digitaliza los pedidos de tu lechería. Consolida por ruta, envía comprobantes por WhatsApp y controla los cobros desde un solo sistema.',
} = Astro.props;

const GA_ID = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=inter:400,500,600,700&display=swap"
      rel="stylesheet"
    />
    {GA_ID && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
        ></script>
        <script define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
