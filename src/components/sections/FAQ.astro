---
import FAQAccordion from '../forms/FAQAccordion';
---

<section id="faq" class="py-12 md:py-20 bg-white">
  <div class="max-w-3xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f172a] mb-4">
        Preguntas frecuentes
      </h2>
      <p class="text-[#475569] text-lg">
        Todo lo que necesitas saber antes de empezar.
      </p>
    </div>

    <FAQAccordion client:visible />
  </div>
</section>
