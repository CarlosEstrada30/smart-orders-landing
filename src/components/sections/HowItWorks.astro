---
---

<section id="como-funciona" class="py-20 md:py-28 bg-[#f8fafc]">
  <div class="max-w-5xl mx-auto px-4">

    <div class="text-center mb-16">
      <span class="inline-block text-xs font-semibold text-[#2563EB] uppercase tracking-widest mb-4">Proceso</span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f172a] mb-4">
        Implementación simple.<br />Operación inmediata.
      </h2>
      <p class="text-[#475569] text-lg max-w-xl mx-auto">
        Sin meses de configuración. Sin procesos complicados. Sin consultores.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-10 left-1/2 -translate-x-1/2 w-full max-w-3xl">
        <div class="mx-16 border-t-2 border-dashed border-[#e2e8f0]"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">

        <!-- Paso 1 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative mb-6">
            <div class="w-20 h-20 rounded-2xl bg-[#2563EB] flex items-center justify-center shadow-lg shadow-blue-200">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-[#2563EB] text-[#2563EB] text-xs font-bold flex items-center justify-center shadow-sm">1</span>
          </div>
          <div class="inline-block bg-blue-50 text-[#2563EB] text-xs font-semibold px-2.5 py-1 rounded-full mb-3 border border-blue-100">Hoy</div>
          <h3 class="text-base font-bold text-[#0f172a] mb-2">Agenda una demo de 30 min</h3>
          <p class="text-sm text-[#475569] leading-relaxed">
            Te mostramos SmartOrders con un caso parecido al tuyo. Sin tecnicismos, sin compromiso.
          </p>
        </div>

        <!-- Paso 2 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative mb-6">
            <div class="w-20 h-20 rounded-2xl bg-[#0f172a] flex items-center justify-center shadow-lg shadow-slate-200">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-[#0f172a] text-[#0f172a] text-xs font-bold flex items-center justify-center shadow-sm">2</span>
          </div>
          <div class="inline-block bg-slate-100 text-[#475569] text-xs font-semibold px-2.5 py-1 rounded-full mb-3 border border-slate-200">48 horas</div>
          <h3 class="text-base font-bold text-[#0f172a] mb-2">Configuramos tu cuenta</h3>
          <p class="text-sm text-[#475569] leading-relaxed">
            Cargamos tus productos, clientes, rutas y precios. Nosotros hacemos el trabajo. Tú solo revisas.
          </p>
        </div>

        <!-- Paso 3 -->
        <div class="flex flex-col items-center text-center">
          <div class="relative mb-6">
            <div class="w-20 h-20 rounded-2xl bg-[#059669] flex items-center justify-center shadow-lg shadow-green-200">
              <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-white border-2 border-[#059669] text-[#059669] text-xs font-bold flex items-center justify-center shadow-sm">3</span>
          </div>
          <div class="inline-block bg-green-50 text-[#059669] text-xs font-semibold px-2.5 py-1 rounded-full mb-3 border border-green-100">Desde el día 1</div>
          <h3 class="text-base font-bold text-[#0f172a] mb-2">Tu equipo empieza a operar</h3>
          <p class="text-sm text-[#475569] leading-relaxed">
            Capacitación incluida. Interfaz sencilla. Tu equipo lo aprende el primer día. Soporte siempre disponible.
          </p>
        </div>

      </div>
    </div>

    <!-- Garantía -->
    <div class="mt-14 bg-[#eff6ff] border border-[#bfdbfe] rounded-2xl p-6 md:p-8 text-center max-w-2xl mx-auto">
      <div class="text-2xl mb-2">🛡️</div>
      <p class="text-[#1e40af] font-bold text-base mb-1">Garantía de arranque</p>
      <p class="text-[#475569] text-sm leading-relaxed">
        Si en 7 días tu equipo no está operando con SmartOrders, te devolvemos el dinero. Sin preguntas.
      </p>
    </div>

  </div>
</section>
