---
const steps = [
  {
    number: '1',
    title: 'Agendas una demo de 30 minutos',
    description:
      'Te mostramos el sistema con un caso parecido al tuyo. Sin tecnicismos, sin compromiso. Solo te explicamos cómo resuelve los problemas de tu operación.',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    number: '2',
    title: 'Configuramos tu cuenta en 48 horas',
    description:
      'Cargamos tus productos, clientes, rutas y precios. Nosotros hacemos el trabajo pesado. Tú solo revisas que esté todo correcto.',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    number: '3',
    title: 'Tu equipo empieza a operar',
    description:
      'Capacitación incluida. Interfaz sencilla. Tu equipo aprende a usar SmartOrders el primer día, sin necesidad de conocimientos técnicos.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<section id="como-funciona" class="py-12 md:py-20 bg-[#f8fafc]">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f172a] mb-4">
        Implementación simple. Operación inmediata.
      </h2>
      <p class="text-[#475569] text-lg max-w-2xl mx-auto">
        Sin meses de configuración. Sin procesos complicados.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-12 left-1/3 right-1/3 h-0.5 bg-[#e2e8f0] z-0"></div>

      {steps.map((step, index) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <!-- Number circle -->
          <div class="w-20 h-20 rounded-full bg-[#2563EB] flex items-center justify-center mb-6 shadow-lg shadow-blue-200 relative">
            <span class="text-2xl font-bold text-white">{step.number}</span>
          </div>

          <h3 class="text-xl font-bold text-[#0f172a] mb-3">{step.title}</h3>
          <p class="text-[#475569] text-sm leading-relaxed max-w-xs">{step.description}</p>

          {index < steps.length - 1 && (
            <div class="md:hidden w-0.5 h-8 bg-[#e2e8f0] mt-6"></div>
          )}
        </div>
      ))}
    </div>

    <!-- Guarantee box -->
    <div class="bg-[#eff6ff] border border-[#bfdbfe] rounded-xl p-6 text-center max-w-xl mx-auto mt-12">
      <p class="text-[#1e40af] font-semibold text-base">
        🛡️ Garantía de arranque
      </p>
      <p class="text-[#475569] text-sm mt-2">
        Si en 7 días tu equipo no está operando con SmartOrders,
        te devolvemos el dinero. Sin preguntas.
      </p>
    </div>
  </div>
</section>
