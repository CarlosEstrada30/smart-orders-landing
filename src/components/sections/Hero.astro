---
---

<section class="pt-28 pb-20 md:pt-36 md:pb-28 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Text content -->
      <div>
        <div class="inline-flex items-center gap-2 bg-blue-50 text-[#2563EB] text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-[#059669] inline-block"></span>
          Solución para lecherías guatemaltecas
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-[#0f172a] leading-tight mb-5">
          Deja de consolidar pedidos a mano.<br />
          <span class="text-[#2563EB]">Tu fábrica de lácteos necesita un sistema real.</span>
        </h1>

        <p class="text-lg text-[#475569] mb-8 leading-relaxed">
          SmartOrders centraliza tus pedidos, genera el consolidado de carga
          por ruta y envía comprobantes automáticos por WhatsApp
          — todo en un solo lugar.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a
            href="#contacto"
            class="bg-[#059669] hover:bg-[#047857] text-white font-semibold px-6 py-3 rounded-lg transition-colors shadow-sm text-center"
          >
            Ver demo gratis →
          </a>
          <a
            href="#como-funciona"
            class="border-2 border-[#e2e8f0] hover:border-[#2563EB] text-[#0f172a] hover:text-[#2563EB] font-semibold px-6 py-3 rounded-lg transition-colors text-center"
          >
            ¿Cómo funciona? ↓
          </a>
        </div>

        <!-- Proof inline -->
        <div class="flex flex-col sm:flex-row gap-4 text-sm text-[#475569]">
          <span class="flex items-center gap-1.5">
            <span class="text-[#059669] font-bold">✓</span>
            Sin instalación
          </span>
          <span class="flex items-center gap-1.5">
            <span class="text-[#059669] font-bold">✓</span>
            Implementación en 48 h
          </span>
          <span class="flex items-center gap-1.5">
            <span class="text-[#059669] font-bold">✓</span>
            Soporte en español
          </span>
        </div>
      </div>

      <!-- Visual placeholder -->
      <div class="relative">
        <div
          class="relative rounded-2xl overflow-hidden shadow-2xl bg-gradient-to-br from-[#2563EB] to-[#059669] aspect-[4/3] flex items-center justify-center"
        >
          <!-- Badge flotante superior izquierdo -->
          <div class="absolute -top-3 -left-3 bg-white rounded-lg shadow-lg px-3 py-2 text-xs font-semibold text-[#059669] border border-[#e2e8f0] flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-[#059669] inline-block"></span>
            Consolidado listo — Ruta Norte
          </div>
          <!-- Badge flotante inferior derecho -->
          <div class="absolute -bottom-3 -right-3 bg-white rounded-lg shadow-lg px-3 py-2 text-xs font-semibold text-[#0f172a] border border-[#e2e8f0]">
            📱 Comprobante enviado por WhatsApp
          </div>
          <!-- Contenido central del placeholder -->
          <div class="text-center text-white/80">
            <div class="text-4xl mb-2">📦</div>
            <div class="text-sm font-medium">Dashboard SmartOrders</div>
            <div class="text-xs opacity-70 mt-1">Pedidos · Rutas · Cobros</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
