---
const features = [
  {
    icon: 'truck',
    title: 'Consolidado de carga por ruta',
    description:
      'Selecciona la fecha y la ruta. SmartOrders suma todos los pedidos activos y genera la lista exacta de productos y cantidades a cargar en cada camión. Imprimible. En segundos.',
    highlight: true,
  },
  {
    icon: 'whatsapp',
    title: 'Comprobantes automáticos por WhatsApp',
    description:
      'Al confirmar un pedido, el sistema envía automáticamente el comprobante al cliente por WhatsApp. Sin copiar, sin reenviar, sin olvidarte.',
    highlight: false,
  },
  {
    icon: 'credit-card',
    title: 'Control de pagos y cobros',
    description:
      'Registra pagos parciales y completos. Consulta el saldo pendiente por cliente. Sabe exactamente quién te debe y cuánto, en tiempo real.',
    highlight: false,
  },
  {
    icon: 'clipboard-list',
    title: 'Pedidos centralizados',
    description:
      'Todos los pedidos en un solo lugar, con historial de cambios, confirmaciones y cancelaciones registradas con hora y usuario.',
    highlight: false,
  },
  {
    icon: 'map-pin',
    title: 'Gestión de rutas',
    description:
      'Asigna pedidos a rutas y conductores. Cada piloto ve en su celular qué debe entregar y en qué orden. Menos llamadas, menos confusión.',
    highlight: false,
  },
  {
    icon: 'tag',
    title: 'Precios diferenciados por ruta',
    description:
      'Define precios distintos para el mismo producto según la ruta o el cliente. El sistema los aplica automáticamente, sin que tengas que recordarlos.',
    highlight: false,
  },
];

const iconPaths: Record<string, string> = {
  'truck': 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l1.5.5M13 16l1.5.5M13 16H9m4 0h2m0 0l1.5-.5M3 6l2.5-3H13m6 3h2v7h-2m-6-7v4',
  'credit-card': 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
  'clipboard-list': 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  'map-pin': 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  'tag': 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z',
};
---

<section id="funcionalidades" class="py-12 md:py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f172a] mb-4">
        Diseñado para cómo opera una fábrica de lácteos
      </h2>
      <p class="text-[#475569] text-lg max-w-2xl mx-auto">
        Cada funcionalidad resuelve un problema real de tu operación diaria.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class={`group rounded-2xl p-6 border transition-all duration-200 ${
          feature.highlight
            ? 'bg-white border-[#2563EB] shadow-md ring-1 ring-[#2563EB]/20'
            : 'bg-[#f8fafc] hover:bg-white border-[#e2e8f0] hover:border-[#2563EB]/30 hover:shadow-md'
        }`}>
          {feature.highlight && (
            <div class="mb-3">
              <span class="inline-block bg-[#2563EB] text-white text-xs font-semibold px-2.5 py-1 rounded-full">Más popular</span>
            </div>
          )}
          <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 transition-colors duration-200 ${
            feature.highlight
              ? 'bg-[#2563EB]'
              : 'bg-blue-100 group-hover:bg-[#2563EB]'
          }`}>
            {feature.icon === 'whatsapp' ? (
              <svg
                class={`w-5 h-5 transition-colors duration-200 ${feature.highlight ? 'text-white' : 'text-[#2563EB] group-hover:text-white'}`}
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            ) : (
              <svg
                class={`w-5 h-5 transition-colors duration-200 ${feature.highlight ? 'text-white' : 'text-[#2563EB] group-hover:text-white'}`}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d={iconPaths[feature.icon]}
                ></path>
              </svg>
            )}
          </div>
          <h3 class="text-base font-bold text-[#0f172a] mb-2">{feature.title}</h3>
          <p class="text-sm text-[#475569] leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
