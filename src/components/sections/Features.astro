---
---

<section id="funcionalidades" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4">

    <!-- Section header -->
    <div class="text-center mb-20">
      <span class="inline-block text-xs font-semibold text-[#2563EB] uppercase tracking-widest mb-4">Funcionalidades</span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#0f172a] mb-4">
        Cada problema de tu operación,<br class="hidden md:block" /> resuelto.
      </h2>
      <p class="text-[#475569] text-lg max-w-2xl mx-auto">
        No es un software genérico adaptado. Fue construido entendiendo cómo opera una fábrica de lácteos de verdad.
      </p>
    </div>

    <!-- Feature 1: Consolidado -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center mb-28">
      <div>
        <span class="inline-block bg-blue-50 text-[#2563EB] text-xs font-semibold px-3 py-1 rounded-full mb-5 border border-blue-100">Más popular</span>
        <h3 class="text-2xl md:text-3xl font-bold text-[#0f172a] mb-4 leading-tight">
          Evita enviar el camión<br />con productos incorrectos.
        </h3>
        <p class="text-[#475569] text-base leading-relaxed mb-6">
          SmartOrders suma automáticamente todos los pedidos activos
          y genera la lista exacta de carga por ruta. En segundos.
          Sin calculadoras, sin Excel, sin errores.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Lista por producto con totales de unidades y valor por ruta</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Filtrable por ruta y fecha — listo para imprimir o compartir</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Antes tardabas 45 min. Ahora: menos de 30 segundos</span>
          </li>
        </ul>
      </div>

      <!-- Screenshot con wrapper mejorado -->
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-[#2563EB]/15 to-[#059669]/10 rounded-3xl blur-2xl scale-95 -z-10"></div>
        <!-- Dark wrapper for the PDF screenshot -->
        <div class="bg-[#1e293b] rounded-2xl p-4 shadow-2xl ring-1 ring-white/10">
          <div class="bg-[#0f172a] rounded-lg px-3 py-2 flex items-center gap-2 mb-3">
            <div class="w-2 h-2 rounded-full bg-red-400/70"></div>
            <div class="w-2 h-2 rounded-full bg-yellow-400/70"></div>
            <div class="w-2 h-2 rounded-full bg-green-400/70"></div>
            <span class="text-[#64748b] text-xs ml-2">Consolidado de Rutas — 27/04/2026</span>
          </div>
          <img
            src="/assets/screenshots/consolidado.png"
            alt="Reporte de consolidado de rutas"
            class="w-full rounded-lg"
            loading="lazy"
          />
        </div>
        <!-- Badge sobre total -->
        <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-xl px-4 py-2.5 border border-[#e2e8f0] z-10">
          <div class="text-xs text-[#475569] font-medium">Total de la ruta</div>
          <div class="text-lg font-bold text-[#059669]">Q 10,871.50</div>
        </div>
      </div>
    </div>

    <!-- Feature 2: WhatsApp -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center mb-28">
      <!-- Screenshot izquierda -->
      <div class="relative order-2 md:order-1">
        <div class="absolute inset-0 bg-gradient-to-br from-green-500/15 to-[#2563EB]/10 rounded-3xl blur-2xl scale-95 -z-10"></div>
        <div class="rounded-2xl overflow-hidden shadow-2xl border border-[#e2e8f0] ring-1 ring-black/5">
          <img
            src="/assets/screenshots/whatsapp-pedido.png"
            alt="Comprobante de pedido con botón Compartir por WhatsApp"
            class="w-full block"
            loading="lazy"
          />
        </div>
        <!-- Badge WhatsApp -->
        <div class="absolute -top-4 -left-4 z-10 bg-[#25d366] text-white rounded-xl shadow-lg px-3 py-2 text-xs font-semibold flex items-center gap-1.5">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Enviado automáticamente
        </div>
      </div>

      <div class="order-1 md:order-2">
        <span class="inline-block bg-green-50 text-[#059669] text-xs font-semibold px-3 py-1 rounded-full mb-5 border border-green-100">WhatsApp integrado</span>
        <h3 class="text-2xl md:text-3xl font-bold text-[#0f172a] mb-4 leading-tight">
          Tus clientes reciben su comprobante sin que tú lo envíes.
        </h3>
        <p class="text-[#475569] text-base leading-relaxed mb-6">
          Al confirmar un pedido, el sistema genera el comprobante
          y lo envía automáticamente por WhatsApp. Sin copiar,
          sin reenviar, sin olvidarte. Tus clientes siempre saben
          qué ordenaron y a qué precio.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Envío automático al confirmar — cero intervención manual</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Comprobante con detalle de productos, cantidades y total</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>También disponible para descargar e imprimir</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Feature 3: Pagos -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center mb-28">
      <div>
        <span class="inline-block bg-blue-50 text-[#2563EB] text-xs font-semibold px-3 py-1 rounded-full mb-5 border border-blue-100">Control de cobros</span>
        <h3 class="text-2xl md:text-3xl font-bold text-[#0f172a] mb-4 leading-tight">
          Nunca más pierdas<br />un cobro pendiente.
        </h3>
        <p class="text-[#475569] text-base leading-relaxed mb-6">
          Registra pagos parciales y completos por pedido.
          Consulta el saldo de cada cliente en tiempo real.
          Deja de rastrear cobros en tu cabeza o en hojas de cálculo.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Estado por pedido: pagado, parcial o pendiente</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Registro de abonos y pagos múltiples por orden</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Saldo pendiente visible por cliente, siempre actualizado</span>
          </li>
        </ul>
      </div>

      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-[#2563EB]/15 to-purple-500/10 rounded-3xl blur-2xl scale-95 -z-10"></div>
        <div class="rounded-2xl overflow-hidden shadow-2xl border border-[#e2e8f0] ring-1 ring-black/5">
          <img
            src="/assets/screenshots/detalle-pagos.png"
            alt="Detalle de orden con resumen de pagos"
            class="w-full block"
            loading="lazy"
          />
        </div>
        <!-- Badge sobre estado de pago -->
        <div class="absolute top-4 right-4 z-10 bg-[#0f172a] text-white rounded-lg px-3 py-1.5 text-xs font-bold shadow-lg flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-[#059669] inline-block"></span>
          Pagado — Q 2,402.00
        </div>
      </div>
    </div>

    <!-- Feature 4: Plan de Producción -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center mb-20">
      <!-- Screenshot izquierda -->
      <div class="relative order-2 md:order-1">
        <div class="absolute inset-0 bg-gradient-to-br from-amber-400/10 to-[#2563EB]/10 rounded-3xl blur-2xl scale-95 -z-10"></div>
        <div class="rounded-2xl overflow-hidden shadow-2xl border border-[#e2e8f0] ring-1 ring-black/5">
          <img
            src="/assets/screenshots/plan-produccion.png"
            alt="Plan de producción estimado"
            class="w-full block"
            loading="lazy"
          />
        </div>
        <!-- Badge total producción -->
        <div class="absolute -bottom-4 -left-4 z-10 bg-white rounded-xl shadow-xl px-4 py-2.5 border border-[#e2e8f0]">
          <div class="text-xs text-[#475569] font-medium">Para mañana</div>
          <div class="text-lg font-bold text-[#0f172a]">~781 unidades</div>
        </div>
      </div>

      <div class="order-1 md:order-2">
        <span class="inline-block bg-amber-50 text-amber-700 text-xs font-semibold px-3 py-1 rounded-full mb-5 border border-amber-100">Plan de producción</span>
        <h3 class="text-2xl md:text-3xl font-bold text-[#0f172a] mb-4 leading-tight">
          Sabe cuánto producir antes de empezar el día.
        </h3>
        <p class="text-[#475569] text-base leading-relaxed mb-6">
          SmartOrders calcula automáticamente las unidades que necesitas
          producir de cada producto, basándose en los pedidos activos.
          Sin suposiciones. Sin desperdicios.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Totales por producto basados en pedidos confirmados</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Indicadores de tendencia: subiendo, bajando o estable</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-[#475569]">
            <span class="text-[#059669] font-bold text-base mt-0.5">✓</span>
            <span>Vista diaria filtrable por ruta o producto</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Cards secundarias -->
    <div class="grid sm:grid-cols-3 gap-6 pt-4 border-t border-[#e2e8f0]">

      <!-- Pedidos centralizados -->
      <div class="group rounded-2xl border border-[#e2e8f0] overflow-hidden hover:shadow-lg hover:border-[#2563EB]/30 transition-all">
        <div class="overflow-hidden">
          <img
            src="/assets/screenshots/ordenes.png"
            alt="Lista de órdenes"
            class="w-full block group-hover:scale-[1.02] transition-transform duration-300"
            loading="lazy"
          />
        </div>
        <div class="p-5 bg-[#f8fafc]">
          <h3 class="text-sm font-bold text-[#0f172a] mb-1.5">Todos los pedidos en un solo lugar</h3>
          <p class="text-xs text-[#475569] leading-relaxed">
            No más chats dispersos. Filtra por ruta, estado o cliente. Historial completo con fecha y usuario.
          </p>
        </div>
      </div>

      <!-- Gestión de rutas -->
      <div class="rounded-2xl border border-[#e2e8f0] bg-[#f8fafc] p-6 hover:shadow-lg hover:border-[#2563EB]/30 transition-all">
        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-sm font-bold text-[#0f172a] mb-1.5">Rutas organizadas, pilotos informados</h3>
        <p class="text-xs text-[#475569] leading-relaxed">
          Asigna zonas de reparto y pilotos. Menos llamadas para coordinar entregas.
        </p>
      </div>

      <!-- Precios por ruta -->
      <div class="rounded-2xl border border-[#e2e8f0] bg-[#f8fafc] p-6 hover:shadow-lg hover:border-[#2563EB]/30 transition-all">
        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
        <h3 class="text-sm font-bold text-[#0f172a] mb-1.5">Precios distintos por ruta o cliente</h3>
        <p class="text-xs text-[#475569] leading-relaxed">
          Define precios diferenciados. El sistema los aplica automáticamente al crear cada orden.
        </p>
      </div>

    </div>
  </div>
</section>
