---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '50200000000';
const WHATSAPP_LINK = `https://wa.me/${waNumber}?text=Hola%2C%20solicité%20una%20demo%20de%20SmartOrders%20y%20quiero%20coordinarla`;
---

<BaseLayout
  title="¡Solicitud recibida! — SmartOrders"
  description="Hemos recibido tu solicitud de demo. Te contactaremos en menos de 24 horas por WhatsApp."
>
  <div class="min-h-screen bg-[#f8fafc] flex flex-col items-center justify-center px-4 py-16">

    <div class="max-w-lg w-full space-y-6">

      <!-- Main confirmation card -->
      <div class="bg-white rounded-2xl shadow-sm border border-[#e2e8f0] p-8 md:p-10 text-center">

        <!-- Animated checkmark -->
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg
            class="w-10 h-10 text-[#059669]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M5 13l4 4L19 7"
            />
          </svg>
        </div>

        <h1 class="text-2xl md:text-3xl font-bold text-[#0f172a] mb-3">
          ¡Solicitud recibida!
        </h1>
        <p class="text-[#475569] leading-relaxed">
          Ya estamos revisando tu información. En menos de 24 horas te contactamos
          por WhatsApp para agendar tu demo personalizada.
        </p>
      </div>

      <!-- What happens next -->
      <div class="bg-white rounded-2xl shadow-sm border border-[#e2e8f0] p-6 md:p-8">
        <h2 class="text-sm font-semibold text-[#0f172a] uppercase tracking-wide mb-6">
          ¿Qué pasa ahora?
        </h2>

        <div class="space-y-0">

          <!-- Step 1 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div class="w-px h-10 bg-[#e2e8f0] mt-1"></div>
            </div>
            <div class="pb-8">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-semibold text-[#0f172a]">Solicitud registrada</span>
                <span class="text-xs bg-green-100 text-[#059669] font-medium px-2 py-0.5 rounded-full">Ahora</span>
              </div>
              <p class="text-sm text-[#475569]">Recibimos tus datos y los estamos revisando.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-blue-50 border-2 border-[#2563EB] flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#2563EB]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div class="w-px h-10 bg-[#e2e8f0] mt-1"></div>
            </div>
            <div class="pb-8">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-semibold text-[#0f172a]">Te escribimos por WhatsApp</span>
                <span class="text-xs bg-blue-50 text-[#2563EB] font-medium px-2 py-0.5 rounded-full">Menos de 24 h</span>
              </div>
              <p class="text-sm text-[#475569]">Un asesor te contacta para confirmar la fecha y hora de tu demo.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-slate-100 border-2 border-[#e2e8f0] flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#94a3b8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-semibold text-[#0f172a]">Demo con los datos de tu fábrica</span>
                <span class="text-xs bg-slate-100 text-[#475569] font-medium px-2 py-0.5 rounded-full">Esta semana</span>
              </div>
              <p class="text-sm text-[#475569]">30 minutos para mostrarte SmartOrders con un caso similar al tuyo.</p>
            </div>
          </div>

        </div>
      </div>

      <!-- CTA buttons -->
      <div class="space-y-3">
        <a
          href={WHATSAPP_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full bg-[#059669] hover:bg-[#047857] text-white font-semibold px-6 py-3.5 rounded-lg transition-colors shadow-sm"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          ¿No quieres esperar? Escríbenos ahora
        </a>

        <a
          href="/"
          class="flex items-center justify-center gap-1.5 w-full border border-[#e2e8f0] hover:border-[#2563EB]/40 text-[#475569] hover:text-[#2563EB] font-medium px-6 py-3 rounded-lg transition-colors text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al inicio
        </a>
      </div>

      <!-- Branding -->
      <div class="text-center pt-2">
        <a href="/" class="text-lg">
          <span class="font-bold text-[#2563EB]">Smart</span><span class="font-normal text-[#0f172a]">Orders</span>
        </a>
      </div>

    </div>
  </div>
</BaseLayout>
